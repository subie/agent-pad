#!/usr/bin/env bash
# agent-signal — manually update an agent's status
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/agent-lib.sh"

usage() {
  echo "Usage: agent-signal <status> <task-name> [note]"
  echo ""
  echo "Update an agent's status. Valid statuses: running, waiting, done, blocked"
  echo ""
  echo "Examples:"
  echo "  agent-signal waiting auth-refactor 'needs review'"
  echo "  agent-signal done auth-refactor 'PR #42 ready'"
  exit 1
}

[[ $# -ge 2 ]] || usage

status="$1"
task="$2"
note="${3:-}"

case "$status" in
  running|waiting|done|blocked) ;;
  *) echo "Error: invalid status '$status'. Use: running, waiting, done, blocked" >&2; exit 1 ;;
esac

agent_write_state "$task" "$status" "$note"
agent_rename_window "$task" "$status"

echo "Signaled: $task → $status${note:+ ($note)}"
