#!/usr/bin/env bash
# agent-start — dispatch an agent into a tmux window
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/agent-lib.sh"

usage() {
  echo "Usage: agent-start <task-name> <command>"
  echo ""
  echo "Start an agent in a new tmux window."
  echo ""
  echo "Examples:"
  echo "  agent-start auth-refactor \"copilot -p 'refactor auth'\""
  echo "  agent-start fix-tests \"copilot -i 'fix flaky tests'\""
  exit 1
}

[[ $# -ge 2 ]] || usage

task="$1"
shift
cmd="$*"

if agent_task_exists "$task"; then
  echo "Error: task '$task' already exists. Use agent-stop first." >&2
  exit 1
fi

agent_ensure_session

# Write the command to its own file so the wrapper can eval it safely,
# preserving quotes, multi-line content, and command substitution such as
# `copilot -i "$(cat <prompt-file>)"`.  Keeping the command in a file avoids
# fragile quote nesting when it is baked into the wrapper.
cmdfile=$(mktemp /tmp/agent-cmd-XXXXXX)
printf '%s' "$cmd" > "$cmdfile"

# Write a wrapper script that runs the command and signals done/blocked on exit.
wrapper=$(mktemp /tmp/agent-wrapper-XXXXXX.sh)
cat > "$wrapper" <<'WRAPPER_HEAD'
#!/usr/bin/env bash
WRAPPER_HEAD
cat >> "$wrapper" <<WRAPPER_BODY
source "$SCRIPT_DIR/agent-lib.sh"
# Discover our own window ID
_AQ_WID=\$(tmux display -p '#{window_id}' 2>/dev/null || true)
# Write initial state with window ID
agent_write_state "$task" "running" "" "\$_AQ_WID"
eval "\$(cat "$cmdfile")"
exit_code=\$?
if [[ \$exit_code -eq 0 ]]; then
  agent_write_state "$task" "done" "exited successfully" "\$_AQ_WID"
  agent_rename_window "$task" "done"
else
  agent_write_state "$task" "blocked" "exited with code \$exit_code" "\$_AQ_WID"
  agent_rename_window "$task" "blocked"
fi
echo ""
echo "=== agent exited (code \$exit_code), press enter to close ==="
read
rm -f "$wrapper" "$cmdfile"
WRAPPER_BODY
chmod +x "$wrapper"

# Create window (wrapper writes state with its own window ID)
tmux new-window -t "$AGENT_SESSION" -n "⏳ ${task}" "$wrapper"

echo "Started: $task"
