#!/usr/bin/env bash
# agent-start — dispatch an agent into a tmux window
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/agent-lib.sh"

usage() {
  echo "Usage: agent-start [--cwd <dir>] <task-name> <command>"
  echo ""
  echo "Start an agent in a new tmux window."
  echo ""
  echo "Options:"
  echo "  --cwd, -C <dir>   Working directory for the agent's tmux window."
  echo ""
  echo "Examples:"
  echo "  agent-start auth-refactor \"copilot -p 'refactor auth'\""
  echo "  agent-start fix-tests \"copilot -i 'fix flaky tests'\""
  echo "  agent-start --cwd /src/proj fix-tests \"copilot -i 'fix tests'\""
  exit 1
}

# Optional leading working-directory option.  agent-pad passes this so the
# tmux window's cwd matches the Copilot "-C" source directory, ensuring panes
# split off the window (which inherit the pane cwd) start in the same place.
cwd=""
if [[ "${1:-}" == "--cwd" || "${1:-}" == "-C" ]]; then
  cwd="${2:-}"
  shift 2 || usage
fi

[[ $# -ge 2 ]] || usage

task="$1"
shift
cmd="$*"

if agent_task_exists "$task"; then
  existing_wid=$(agent_get_window_id "$task")
  if agent_window_alive "$existing_wid"; then
    echo "Error: task '$task' already exists. Use agent-stop first." >&2
    exit 1
  fi
  # Stale state: the recorded window is gone (e.g. just killed, or it exited
  # and the file lingered).  Reclaim the name by removing the stale file so
  # the same task name can be reused.
  rm -f "${AGENT_STATE_DIR}/${task}"
fi

agent_ensure_session

# Write the command to its own file so the wrapper can eval it safely,
# preserving quotes, multi-line content, and command substitution such as
# `copilot -i "$(cat <prompt-file>)"`.  Keeping the command in a file avoids
# fragile quote nesting when it is baked into the wrapper.
cmdfile=$(mktemp /tmp/agent-cmd-XXXXXX)
printf '%s' "$cmd" > "$cmdfile"

# Write a wrapper script that runs the command and signals done/blocked on exit.
wrapper=$(mktemp /tmp/agent-wrapper-XXXXXX.sh)
cat > "$wrapper" <<'WRAPPER_HEAD'
#!/usr/bin/env bash
WRAPPER_HEAD
cat >> "$wrapper" <<WRAPPER_BODY
source "$SCRIPT_DIR/agent-lib.sh"
# Discover our own window ID.  Resolve it from \$TMUX_PANE (the pane tmux
# assigns to this wrapper) rather than a bare 'tmux display', which would
# report the *active client's* window and record the wrong id when several
# agents launch around the same time.
_AQ_WID=\$(tmux display -p -t "\${TMUX_PANE:-}" '#{window_id}' 2>/dev/null || true)
[[ -n "\$_AQ_WID" ]] || _AQ_WID=\$(tmux display -p '#{window_id}' 2>/dev/null || true)
# Write initial state with window ID
agent_write_state "$task" "running" "" "\$_AQ_WID"
eval "\$(cat "$cmdfile")"
exit_code=\$?
# The task may have been renamed while running; resolve our current name from
# our window id so the exit-time state write updates the right file.  If no
# state file claims our window id, the task was stopped or its name was
# reclaimed by another agent — do not resurrect or clobber state in that case.
cur_task=\$(agent_task_for_window "\$_AQ_WID")
if [[ -n "\$cur_task" ]]; then
  if [[ \$exit_code -eq 0 ]]; then
    agent_write_state "\$cur_task" "done" "exited successfully" "\$_AQ_WID"
    agent_rename_window "\$cur_task" "done" "\$_AQ_WID"
  else
    agent_write_state "\$cur_task" "blocked" "exited with code \$exit_code" "\$_AQ_WID"
    agent_rename_window "\$cur_task" "blocked" "\$_AQ_WID"
  fi
fi
echo ""
echo "=== agent exited (code \$exit_code), press enter to close ==="
read
rm -f "$wrapper" "$cmdfile"
WRAPPER_BODY
chmod +x "$wrapper"

# Create window (wrapper writes state with its own window ID).  When a cwd was
# provided, start the window there so split panes inherit the right directory.
if [[ -n "$cwd" ]]; then
  tmux new-window -t "$AGENT_SESSION" -c "$cwd" -n "⏳ ${task}" "$wrapper"
else
  tmux new-window -t "$AGENT_SESSION" -n "⏳ ${task}" "$wrapper"
fi

echo "Started: $task"
