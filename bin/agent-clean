#!/usr/bin/env bash
# agent-clean — remove done state files and dead windows
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/agent-lib.sh"

agent_ensure_state_dir

cleaned=0

for f in "${AGENT_STATE_DIR}"/*; do
  [[ -f "$f" ]] || continue
  IFS='|' read -r status task ts note < "$f"

  if [[ "$status" == "done" ]]; then
    wid=$(awk -F'|' '{print $5}' "$f")
    # Remove state file
    rm -f "$f"
    # Try to kill window if it still exists
    if [[ -n "$wid" ]]; then
      tmux kill-window -t "$wid" 2>/dev/null || true
    fi
    echo "Cleaned: $task"
    ((cleaned++))
  fi
done

if [[ $cleaned -eq 0 ]]; then
  echo "Nothing to clean."
else
  echo "Cleaned $cleaned task(s)."
fi
